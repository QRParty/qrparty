rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── HELPERS ──────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isUser(uid) {
      return request.auth.uid == uid;
    }

    function eventData(eventId) {
      return get(/databases/$(database)/documents/events/$(eventId)).data;
    }

    function isEventHost(eventId) {
      return isSignedIn() && eventData(eventId).hostId == request.auth.uid;
    }

    function isCoHost(eventId) {
      // `coHosts` is an optional array on the event doc — legacy events
      // and any event whose host never added co-hosts won't have the
      // field at all. Without the `'coHosts' in ...` guard, the `in`
      // operator below would error on a null read and the surrounding
      // isHostOrCoHost expression would fail closed even for legitimate
      // hosts. Short-circuiting on field-absence keeps the rule safe.
      return isSignedIn()
        && 'coHosts' in eventData(eventId)
        && request.auth.uid in eventData(eventId).coHosts;
    }

    function isHostOrCoHost(eventId) {
      return isEventHost(eventId) || isCoHost(eventId);
    }

    function isAdmin() {
      return isSignedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // ── USERS ─────────────────────────────────────────────────────────────────
    // Users can read and write their own profile document.
    // Reads (both `get` and `list`) are open to all signed-in users so
    // host-side fan-out flows work without case-by-case helpers:
    //   • HQ→Business invite send (headquarters_home_feed_screen.dart:
    //     _sendInvite) — `where('email', '==', x).limit(1)` query.
    //   • Host notification fan-out (host_notifications_screen.dart:
    //     _sendNotification) — per-guest `users/{uid}.get()` to pull
    //     fcmToken / email for push + Trigger Email fallback.
    //   • Co-host email lookups (create_event_screen.dart) — same
    //     query shape as the invite-send path.
    //
    // Firestore rules can't gate queries by which field is being
    // filtered on, so opening `list` already permits enumeration of
    // any indexed field. Opening `get` adds no surface area beyond
    // that — it just lets a caller skip the query when the uid is
    // already known. Writes stay locked to the doc owner.
    //
    // PRE-PUBLIC-LAUNCH TODO: replace this with callable Cloud
    // Functions (admin SDK lookups that return just the fields each
    // caller needs — orgId/accountType for invites, fcmToken/email
    // for notifications) and revert `get`/`list` to admin-only.
    // Tracked as part of the soft-launch hardening pass.

    match /users/{uid} {
      allow get, list: if isSignedIn();
      allow write:     if isSignedIn() && isUser(uid);
    }

    // ── CONTACT GROUPS (Gmail-style labels on the business Contacts tab) ─────
    // Per-user subcollection — owner reads/writes their own groups only.
    // Group docs hold {name, memberEmails: list<string>}. Written from the
    // Contacts tab in business_home_feed_screen.dart; the Add-to-Group
    // sheet uses arrayUnion/arrayRemove on memberEmails.

    match /users/{userId}/contactGroups/{groupId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── EVENTS ────────────────────────────────────────────────────────────────
    // Any authenticated user can read any event (required for the QR scan guest
    // flow and the Explore tab).  Only the document owner (host) can mutate it,
    // and they cannot reassign ownership by changing hostId.

    match /events/{eventId} {
      allow read: if eventId == 'demo-event' || eventId == 'pta-demo-event' || eventId == 'pgms-pta-demo' || isSignedIn();

      // Anonymous deep-link guests sign in via signInAnonymously() so
      // they can read events + RSVP without creating an account. They
      // satisfy isSignedIn() and have a uid, which means without this
      // extra guard they could create real events under a throwaway
      // anon UID (defeating the host-account model). The client-side
      // routing in HomeRouter already keeps anon users out of the
      // create-event flow; this rule is defense-in-depth.
      //
      // The sign_in_provider claim is set by Firebase Auth to
      // 'anonymous' for signInAnonymously() sessions and to the
      // provider id ('password', 'google.com', etc.) for everyone else.
      // After linkWithCredential upgrades an anon user to a real
      // account (see welcome_screen.dart), the token re-issues with
      // the new provider, so a guest who upgrades inside the same
      // session can immediately create events without re-auth.
      allow create: if isSignedIn()
        && request.auth.token.firebase.sign_in_provider != 'anonymous'
        && request.resource.data.hostId == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0;

      allow update: if isSignedIn()
        && (
          // Main host: full update, cannot transfer ownership
          (resource.data.hostId == request.auth.uid
            && request.resource.data.hostId == resource.data.hostId)
          ||
          // Co-host: can update but cannot change hostId or coHosts
          (isCoHost(eventId)
            && request.resource.data.hostId == resource.data.hostId
            && request.resource.data.coHosts == resource.data.coHosts)
          ||
          // RSVP counter increments — any signed-in user (including
          // anonymous web visitors on event.html) may update ONLY the
          // yes/maybe/no fields, no others. The hasOnly() guard makes
          // this path useless for anything except keeping the cached
          // counters on the event doc in sync with the rsvps
          // subcollection. Hosts already cover this in their full
          // update branch above; this is purely the web-RSVP path.
          (request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['yes', 'maybe', 'no']))
          ||
          // Wishlist / checklist claim from the web RSVP page. The web
          // page rewrites the entire wishlist array (read-modify-write
          // pattern — Firestore can't increment one element of an
          // array). hasOnly(['wishlist']) confines the blast radius to
          // exactly this field so a misbehaving client can't, say,
          // delete the event by zeroing other fields. The downside is a
          // determined attacker could clobber the wishlist; that's
          // acceptable for an invited-only RSVP page where every guest
          // already had the link, and recoverable from the host side
          // (it's just an array on the event doc).
          (request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['wishlist']))
        );

      // Delete permissions:
      //   • The event's host (matches existing single-account ownership)
      //   • Admins (support / cleanup)
      //   • The org owner of any org this event is linked to. This lets a
      //     Headquarters account owner remove events that linked Business
      //     accounts created under their org. Linked accounts that are not
      //     the host cannot delete (they'd fail the hostId check and aren't
      //     org owners themselves).
      allow delete: if isSignedIn()
        && (
          resource.data.hostId == request.auth.uid
          || isAdmin()
          || (
            resource.data.orgId is string
            && get(/databases/$(database)/documents/organizations/$(resource.data.orgId)).data.ownerId == request.auth.uid
          )
        );

      // ── RSVPs ───────────────────────────────────────────────────────────────
      // Two write paths share this collection:
      //   • App RSVP — doc id is the guest's auth uid; only that user can
      //     read/update it. Standard per-account flow.
      //   • Web RSVP — doc id is auto-generated by the client. Each web
      //     submit creates a NEW doc, so multiple guests sharing a phone
      //     can RSVP independently without overwriting each other. The
      //     doc carries source=='web' + email so the host can dedupe.
      //
      // Read access is intentionally open to any signed-in user so guests
      // can see the live headcount + guest list for events they've been
      // invited to. The privacy trade-off (guest names/emails are visible
      // to other invited guests) is acceptable for an invited-only party
      // app. Hosts who don't want this should keep their event link
      // private — the rsvps subcollection is only enumerable by callers
      // who already have the eventId.

      match /rsvps/{rsvpId} {
        allow read: if isSignedIn();

        allow create, update: if isSignedIn()
          && isUser(rsvpId)
          && request.resource.data.status in ['Yes', 'Maybe', 'No'];

        // Web RSVP create — anonymous auth is fine; the doc id is
        // auto-generated by the client (NOT email-keyed) so multiple
        // guests sharing a browser session each get their own doc.
        // Validation pins source='web', a valid email, and a valid
        // status; create-only keeps a returning anon visitor from
        // rewriting someone else's RSVP.
        allow create: if isSignedIn()
          && request.resource.data.source == 'web'
          && request.resource.data.email is string
          && request.resource.data.email.size() > 0
          && request.resource.data.status in ['Yes', 'Maybe', 'No']
          && request.resource.data.name is string
          && request.resource.data.name.size() > 0;

        allow delete: if isSignedIn()
          && (isUser(rsvpId) || isHostOrCoHost(eventId));
      }

      // ── PHOTOS ──────────────────────────────────────────────────────────────
      // Any authenticated user can read photos and upload their own.
      // Liking a photo (toggling uid in the likes array) is allowed for any
      // signed-in user.  Full updates and deletes are restricted to the
      // uploader or the event host.

      match /photos/{photoId} {
        allow read: if isSignedIn();

        allow create: if isSignedIn()
          && request.resource.data.uploaderUid == request.auth.uid
          && request.resource.data.url is string
          && request.resource.data.url.size() > 0;

        // Any authenticated user may update only the likes array (like/unlike).
        // The uploader, host, or co-host may update any field.
        allow update: if isSignedIn() && (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes'])
          || resource.data.uploaderUid == request.auth.uid
          || isHostOrCoHost(eventId)
        );

        allow delete: if isSignedIn()
          && (resource.data.uploaderUid == request.auth.uid || isHostOrCoHost(eventId));
      }

      // ── WISHLIST CONTRIBUTIONS ───────────────────────────────────────────────
      match /wishlist_contributions/{uid} {
        allow read: if isSignedIn() && (isUser(uid) || isEventHost(eventId) || isAdmin());
        allow write: if isSignedIn() && isUser(uid);
      }

      // ── WISHLIST ITEMS (host-curated, shared from external apps) ────────────
      // Subcollection populated when the host or a co-host shares a product
      // URL into QR Party from another app. Item shape:
      //   { name, url, imageUrl, price, notes, contributed,
      //     addedBy, addedAt, claimed, claimedBy }
      // Reads: any signed-in user (parent event is signed-in-readable).
      // Creates: HOST or CO-HOST only — guests cannot add items. Adder must
      //          stamp themselves as `addedBy`, start unclaimed, with zero
      //          contributions.
      // Updates: guests may flip claim state OR contribute money (which
      //          touches `contributed`); the host/co-host can edit any
      //          field except reassigning `addedBy`.
      // Deletes: host/co-host only.

      match /wishlist/{itemId} {
        allow read: if isSignedIn();

        allow create: if isHostOrCoHost(eventId)
          && request.resource.data.addedBy == request.auth.uid
          && request.resource.data.claimed == false
          && request.resource.data.claimedBy == null
          && request.resource.data.name is string
          && request.resource.data.name.size() > 0
          && request.resource.data.url is string;

        allow update: if isSignedIn() && (
          // Any guest may flip claim state and/or contribute money. We
          // limit them to that exact set of fields so they can't rename
          // the item or change the URL.
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['claimed', 'claimedBy', 'contributed'])
          ||
          // Host/co-host can edit any field except the adder identity.
          (isHostOrCoHost(eventId)
            && request.resource.data.addedBy == resource.data.addedBy)
        );

        allow delete: if isHostOrCoHost(eventId);
      }
    }

    // ── ORGANIZATIONS ─────────────────────────────────────────────────────────
    // Org pages are public-readable so org.html (and unauth scanners) can render
    // them. Mutations are restricted to the owner; ownerId can never be reassigned.
    // BusinessPlus gating is enforced client-side; the rules only ensure ownership.

    match /organizations/{orgId} {
      allow read: if true;

      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0;

      allow update: if isSignedIn()
        && resource.data.ownerId == request.auth.uid
        && request.resource.data.ownerId == resource.data.ownerId;

      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;

      // Per-event link docs the org owner uses to pick what shows on the org page.
      match /events/{eventId} {
        allow read: if true;
        allow write: if isSignedIn()
          && get(/databases/$(database)/documents/organizations/$(orgId)).data.ownerId == request.auth.uid;
      }

      // ── HQ → BUSINESS LINK INVITES ──────────────────────────────────────────
      // Subcollection on the BUSINESS-side org doc. Doc id is the inviting
      // HQ's orgId so re-sending the same invite is idempotent (overwrites
      // an existing pending one rather than spawning duplicates).
      //
      // Lifecycle:
      //   1. HQ creates an invite at /organizations/{businessOrgId}/invites/{hqOrgId}
      //      with status='pending'.
      //   2. Business sees it via a snapshot listener on its own org's invites
      //      subcollection and shows an accept/decline banner.
      //   3a. Decline: Business updates status pending → declined (rule below).
      //   3b. Accept: Business calls the `acceptOrgInvite` Cloud Function,
      //       which uses Admin SDK to atomically (a) flip status to
      //       'accepted', (b) set parentOrgId+linkedAt on the Business org
      //       doc, and (c) append uid+orgId to the HQ org's linkedBusiness*
      //       arrays. The CF bypasses these rules entirely, which is why
      //       the update rule below only authorizes the decline transition.
      //   4. Either party can delete the invite for cleanup; HQ delete also
      //      doubles as an explicit revoke for pending invites.
      //
      // The match path's outer `{orgId}` wildcard is the BUSINESS org id;
      // the inner `{hqOrgId}` is the inviting HQ's org id. Within these
      // rules:
      //   • orgId   = the Business doc that holds the subcollection
      //   • hqOrgId = the HQ doc that originated the invite (== doc id here)
      match /invites/{hqOrgId} {
        // Read: either party. The HQ-side read is dead today (no "view
        // sent invites" UI yet) but rule-ready for when that ships.
        allow read: if isSignedIn()
          && (
            get(/databases/$(database)/documents/organizations/$(orgId)).data.ownerId == request.auth.uid
            || get(/databases/$(database)/documents/organizations/$(hqOrgId)).data.ownerId == request.auth.uid
          );

        // Create: HQ owner of the doc-id'd org sends an invite. Doc id
        // must equal the HQ's orgId so we can verify ownership via a
        // single get() against the HQ doc. Payload must self-identify
        // (hqOrgId, hqOwnerUid, hqOrgName) and start in pending status.
        // accountType validation (HQ='businessPlus', target='business')
        // is enforced client-side at send time AND re-checked inside the
        // acceptOrgInvite Cloud Function — duplicating it here would
        // require yet another get() with no security benefit since the
        // CF is the actual gate.
        allow create: if isSignedIn()
          && get(/databases/$(database)/documents/organizations/$(hqOrgId)).data.ownerId == request.auth.uid
          && request.resource.data.hqOrgId    == hqOrgId
          && request.resource.data.hqOwnerUid == request.auth.uid
          && request.resource.data.status     == 'pending'
          && request.resource.data.hqOrgName  is string
          && request.resource.data.hqOrgName.size() > 0;

        // Update: ONLY the Business owner, ONLY the decline transition.
        // Accept lives in the Cloud Function because it has to write
        // three docs atomically (this invite, the Business org doc, and
        // the HQ org doc's linkedBusiness arrays). Status is one-way per
        // the agreed invariant — current must be 'pending', new must be
        // 'declined'. respondedAt is allowed alongside status so the
        // client can stamp the response time.
        allow update: if isSignedIn()
          && get(/databases/$(database)/documents/organizations/$(orgId)).data.ownerId == request.auth.uid
          && resource.data.status == 'pending'
          && request.resource.data.status == 'declined'
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'respondedAt']);

        // Delete: either party.
        //   • HQ owner: revoke a pending or stale invite.
        //   • Business owner: tidy up after responding (remove a
        //     declined invite from their banner stream, etc.).
        allow delete: if isSignedIn()
          && (
            get(/databases/$(database)/documents/organizations/$(orgId)).data.ownerId == request.auth.uid
            || get(/databases/$(database)/documents/organizations/$(hqOrgId)).data.ownerId == request.auth.uid
          );
      }
    }

    // ── BUSINESSES (per-account public QR landing page) ──────────────────────
    // Each Business / Headquarters account that generates a permanent business
    // QR code provisions a doc here keyed by `slug`. The public web page at
    // partywithqr.com/biz/{slug} resolves the slug to ownerId, then lists the
    // owner's upcoming public events. Mirrors the organizations/{orgId} pattern
    // used by /org/{orgId}: world-readable so anonymous scanners can render the
    // page, owner-only writes, ownerId can never be reassigned.
    //
    // Slug uniqueness is enforced by using the slug AS the document id —
    // create writes that target an existing slug fail at the create rule
    // because `resource` is non-null on a doc that already exists, and the
    // `&& resource == null` guard rejects clobbering. (Firestore semantics:
    // for create rules, an existing doc makes `resource` non-null and the
    // rule's create branch never fires; the update branch then runs and
    // requires the caller to be the existing owner.)

    match /businesses/{slug} {
      allow read: if true;

      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0;

      allow update: if isSignedIn()
        && resource.data.ownerId == request.auth.uid
        && request.resource.data.ownerId == resource.data.ownerId;

      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    // ── RECURRING EVENT SERIES ────────────────────────────────────────────────
    // A series doc stores the rule + template used to auto-generate the next
    // event. Read/write restricted to the series owner; Cloud Functions (Admin
    // SDK) bypass these rules.

    match /recurringEvents/{seriesId} {
      allow read:   if isSignedIn() && resource.data.hostId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.hostId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.hostId == request.auth.uid
                      && request.resource.data.hostId == resource.data.hostId;
      allow delete: if isSignedIn() && resource.data.hostId == request.auth.uid;
    }

    // ── MERCH ORDERS ──────────────────────────────────────────────────────────
    // Created exclusively by the createMerchOrder Cloud Function (Admin SDK
    // bypasses rules). Customers can read their own; admins can read + update
    // any (status changes, tracking, notes, cost). No client-side creates.

    match /orders/{orderId} {
      allow read:   if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin();
      allow create, delete: if false;
    }

    // ── EMAIL OUTBOX ─────────────────────────────────────────────────────────
    // Consumed by the Firebase Trigger Email extension. The host
    // notification flow writes to this collection directly to email
    // RSVP'd guests who lack an FCM token (typically web RSVPs that
    // never auth'd through the app). Authorization is anchored to the
    // event the message is about: only the host or a co-host of that
    // event may create a mail doc, and the doc must include `eventId`
    // so the rule can perform the host check. Reads/updates/deletes
    // remain locked — clients should never enumerate or mutate the
    // mail queue.
    //
    // Required client-written shape:
    //   { to: list<string>, message: { subject: string, ... },
    //     eventId: string, ... }

    match /mail/{docId} {
      allow read, update, delete: if false;
      allow create: if isSignedIn()
        && request.resource.data.eventId is string
        && isHostOrCoHost(request.resource.data.eventId)
        && request.resource.data.to is list
        && request.resource.data.message is map;
    }

    // ── ADMIN CONFIG ──────────────────────────────────────────────────────────
    // Read and write restricted to admins only.

    match /adminConfig/{docId} {
      allow read, write: if isAdmin();
    }

    // ── NOTIFICATION QUEUE ────────────────────────────────────────────────────
    // Written by clients to trigger a multicast push (e.g. host blasts a
    // message to every guest). A Cloud Function then drains the queue via
    // the Admin SDK (which bypasses these rules entirely).
    //
    // create — gated to the event's host / co-host (or admin). The doc
    //   MUST include an eventId field so the rule can verify ownership;
    //   any client write missing it falls through and is rejected.
    // read / update / delete — Cloud Function only, never the client.
    //
    // Note: in a create rule, the doc being written lives at
    // `request.resource.data` (the existing `resource` is null since the
    // doc doesn't exist yet) — checking `resource.data.eventId` would
    // always be null and reject every write.

    match /notificationQueue/{docId} {
      allow create: if isSignedIn()
        && request.resource.data.eventId is string
        && (isHostOrCoHost(request.resource.data.eventId) || isAdmin());
      allow read, update, delete: if false;
    }

    // ── NOTIFICATION TASKS ────────────────────────────────────────────────────
    // The app writes tasks here (event_updated alerts, photo-expiry warnings).
    // Cloud Functions process and clean up via Admin SDK.
    // Use allow write (create + update) because the app uses .set() which may
    // create or overwrite a document (e.g. the photo-expiry task per event).

    match /notificationTasks/{docId} {
      allow write: if isSignedIn();
      allow read, delete: if false;
    }

    // ── REPORTS ──────────────────────────────────────────────────────────────
    // User-submitted moderation flags. Any signed-in user can create a
    // report on a photo they're viewing in the picture wall; only admins
    // (via the Admin SDK) read/triage them. The create rule pins
    // `reportedBy` to the caller's uid so a malicious client can't forge
    // reports under another user's name.
    //
    // Required shape:
    //   { photoUrl: string, eventId: string, reportedBy: string,
    //     reason: string, timestamp: Timestamp }
    // Optional: photoId, details (free-text for the "Other" reason).

    match /reports/{reportId} {
      allow create: if isSignedIn()
        && request.resource.data.reportedBy == request.auth.uid
        && request.resource.data.photoUrl is string
        && request.resource.data.eventId is string
        && request.resource.data.reason is string
        && request.resource.data.reason.size() > 0;
      // Triage happens out-of-band (Admin SDK / dashboard); clients
      // never read or mutate reports they've already filed.
      allow read, update, delete: if false;
    }

    // ── COLLECTION-GROUP READ FOR OWN RSVPs ──────────────────────────────────
    // Required by home_feed_screen.dart's `_subscribeToAttendingEvents`
    // collectionGroup query, which reads every rsvps doc across every
    // event subcollection where uid == currentUser.uid AND status == 'Yes'.
    // The path-scoped match on /events/{eventId}/rsvps/{rsvpId} above only
    // grants reads inside that exact path; collectionGroup queries hit
    // the cross-collection scope and need their own rule.
    //
    // The `resource.data.uid == request.auth.uid` guard means a guest
    // can only enumerate their OWN rsvp docs across the database — no
    // way to scrape every event's guest list with a collectionGroup
    // probe. Web-source rsvps (auto-id docs) carry `uid` too as of the
    // current writer; the rule rejects any legacy doc that's missing
    // the field, which is acceptable because those couldn't have been
    // written by the requesting user anyway.

    match /{path=**}/rsvps/{rsvpId} {
      allow read: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }
  }
}
